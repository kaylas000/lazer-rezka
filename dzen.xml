---
layout: null
permalink: /dzen.xml
sitemap: false
---

<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0"
  xmlns:content="http://purl.org/rss/1.0/modules/content/"
  xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ site.title | xml_escape }}</title>
    <link>{{ site.url }}</link>
    <description>{{ site.description | strip_newlines | xml_escape }}</description>
    <language>ru</language>
    <atom:link href="{{ '/dzen.xml' | absolute_url }}" rel="self" type="application/rss+xml"/>

    {% assign max_items = 20 %}
    {% assign count = 0 %}

    {% for post in site.posts %}
      {% if count >= max_items %}{% break %}{% endif %}

      {% assign cover = post.image | default: site.image | absolute_url %}
      {% assign mime = 'image/jpeg' %}
      {% if cover contains '.png' %}{% assign mime = 'image/png' %}{% endif %}
      {% if cover contains '.gif' %}{% assign mime = 'image/gif' %}{% endif %}
      {% assign text = post.excerpt | strip_html | strip_newlines | replace: '  ', ' ' %}

      <item>
        <title>{{ post.title | xml_escape }}</title>
        <link>{{ post.url | absolute_url }}</link>
        <guid isPermaLink="true">{{ post.url | absolute_url }}</guid>
        <pubDate>{{ post.date | date_to_rfc822 }}</pubDate>

        <!-- Дзен: безопасный режим — отправлять как черновик-статью, не индексировать, комментарии открыты -->
        <category>native-draft</category>
        <category>format-article</category>
        <category>noindex</category>
        <category>comment-all</category>

        <enclosure url="{{ cover }}" type="{{ mime }}"/>

        <description>{{ post.excerpt | strip_html | strip_newlines | truncate: 220 | xml_escape }}</description>

        <content:encoded><![CDATA[
          <h1>{{ post.title | escape }}</h1>
          <figure><img src="{{ cover }}" /></figure>
          <p>{{ text | escape }}</p>
          <p><a href="{{ post.url | absolute_url }}">Читать на сайте</a></p>
        ]]></content:encoded>
      </item>

      {% assign count = count | plus: 1 %}
    {% endfor %}

  </channel>
</rss>
